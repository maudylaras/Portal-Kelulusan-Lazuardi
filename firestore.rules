rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Collection: Users
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());

      allow create: if isSignedIn() && isOwner(userId)
                    && request.resource.data.uid == userId
                    && request.resource.data.email is string
                    && request.resource.data.role in ['user', 'admin']
                    && (request.resource.data.role == 'user' || (request.auth.token.email.matches('(?i).*maudy@lazuardi.*')));

      allow update: if isSignedIn() && isOwner(userId)
                    && request.resource.data.uid == userId
                    && (resource.data.role == 'admin' ? request.resource.data.role == 'admin' : true)
                    && (request.resource.data.role == 'admin' ? (resource.data.role == 'admin' || request.auth.token.email.matches('(?i).*maudy@lazuardi.*')) : true);
    }

    // Collection: Batches
    match /batches/{batchId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }
  }
}
